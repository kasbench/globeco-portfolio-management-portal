# GlobeCo Portfolio Management Portal Environment Variables

# Application Configuration
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_VERSION=0.1.0

# Backend Service URLs (Docker network hostnames)
NEXT_PUBLIC_PORTFOLIO_SERVICE_URL=http://globeco-portfolio-service:8001
NEXT_PUBLIC_ORDER_SERVICE_URL=http://globeco-order-service:8081
NEXT_PUBLIC_TRADE_SERVICE_URL=http://globeco-trade-service:8082
NEXT_PUBLIC_PRICING_SERVICE_URL=http://globeco-pricing-service:8083
NEXT_PUBLIC_EXECUTION_SERVICE_URL=http://globeco-execution-service:8084
NEXT_PUBLIC_PORTFOLIO_ACCOUNTING_SERVICE_URL=http://globeco-portfolio-accounting-service:8087
NEXT_PUBLIC_SECURITY_SERVICE_URL=http://globeco-security-service:8000

# Default User Role (for benchmarking)
NEXT_PUBLIC_DEFAULT_ROLE=internal

# Feature Flags
NEXT_PUBLIC_ENABLE_STORYBOOK=true
NEXT_PUBLIC_ENABLE_MOCK_DATA=true

# Monitoring and Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Development Settings
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_RETRY_ATTEMPTS=3

# Docker Network Configuration
DOCKER_NETWORK=my-network

# Order Generation Service Configuration
NEXT_PUBLIC_ORDER_GENERATION_SERVICE_HOST=localhost
NEXT_PUBLIC_ORDER_GENERATION_SERVICE_PORT=8088

# Other backend services (for future integration)
NEXT_PUBLIC_PORTFOLIO_SERVICE_HOST=localhost
NEXT_PUBLIC_PORTFOLIO_SERVICE_PORT=8001

NEXT_PUBLIC_ORDER_SERVICE_HOST=localhost
NEXT_PUBLIC_ORDER_SERVICE_PORT=8081

NEXT_PUBLIC_TRADE_SERVICE_HOST=localhost
NEXT_PUBLIC_TRADE_SERVICE_PORT=8082

NEXT_PUBLIC_PRICING_SERVICE_HOST=localhost
NEXT_PUBLIC_PRICING_SERVICE_PORT=8083

NEXT_PUBLIC_EXECUTION_SERVICE_HOST=localhost
NEXT_PUBLIC_EXECUTION_SERVICE_PORT=8084

NEXT_PUBLIC_PORTFOLIO_ACCOUNTING_SERVICE_HOST=localhost
NEXT_PUBLIC_PORTFOLIO_ACCOUNTING_SERVICE_PORT=8087

NEXT_PUBLIC_SECURITY_SERVICE_HOST=localhost
NEXT_PUBLIC_SECURITY_SERVICE_PORT=8000

# Order Submission Configuration
# Maximum number of orders per batch (max: 1000)
NEXT_PUBLIC_ORDER_BATCH_SIZE=1000
# Default blotter ID for order submission (1=Default)
NEXT_PUBLIC_ORDER_DEFAULT_BLOTTER_ID=1
# Default status ID for new orders (1=New)
NEXT_PUBLIC_ORDER_DEFAULT_STATUS_ID=1
# Order type IDs for BUY/SELL operations
NEXT_PUBLIC_ORDER_BUY_TYPE_ID=1
NEXT_PUBLIC_ORDER_SELL_TYPE_ID=2
# API timeout for order submission requests (milliseconds)
NEXT_PUBLIC_ORDER_SUBMISSION_TIMEOUT=30000
# Retry configuration for failed submissions
NEXT_PUBLIC_ORDER_RETRY_MAX_ATTEMPTS=3
NEXT_PUBLIC_ORDER_RETRY_DELAY=1000
NEXT_PUBLIC_ORDER_RETRY_BACKOFF_MULTIPLIER=2 